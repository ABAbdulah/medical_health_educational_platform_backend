# Railway deployment — set these in the Railway dashboard (Variables tab)
DATABASE_URL=postgresql://...              # Railway provides this automatically
# AI provider — hosted Qwen via an OpenAI-compatible API. See docs/AI_PROVIDER.md.
LLM_PROVIDER=openai
LLM_BASE_URL=https://openrouter.ai/api/v1  # or Groq / Together / DashScope base URL
LLM_API_KEY=your_provider_key_here
LLM_MODEL=qwen/qwen-2.5-7b-instruct        # provider-specific model id
# LLM_TUTOR_MODEL=                          # optional; falls back to LLM_MODEL
# Legacy fallback (set LLM_PROVIDER=anthropic to use):
# ANTHROPIC_API_KEY=your_key_here
JWT_SECRET=your_secret_here
ENVIRONMENT=production
FRONTEND_URL=https://your-frontend.up.railway.app
