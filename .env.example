# docker-compose maps the dev postgres container to host port 5433
# (5432 is often taken by a natively installed PostgreSQL)
DATABASE_URL=postgresql://amc:amc_password@localhost:5433/amccompass
# AI provider — local dev defaults to Qwen via Ollama (OpenAI-compatible /v1).
# See docs/AI_PROVIDER.md for hosted providers and switching back to Anthropic.
LLM_PROVIDER=openai
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama                          # any non-empty string for local Ollama
LLM_MODEL=qwen2.5:7b-instruct-q4_K_M
# LLM_TUTOR_MODEL=                           # optional; falls back to LLM_MODEL
# Legacy fallback (set LLM_PROVIDER=anthropic to use):
# ANTHROPIC_API_KEY=your_key_here
JWT_SECRET=your_secret_here
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3001
