# docker-compose maps the dev postgres container to host port 5433
# (5432 is often taken by a natively installed PostgreSQL)
DATABASE_URL=postgresql://amc:amc_password@localhost:5433/amccompass
ANTHROPIC_API_KEY=your_key_here
OLLAMA_BASE_URL=http://localhost:11434     # Leave EMPTY on Railway
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
JWT_SECRET=your_secret_here
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3001
